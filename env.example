# ── AI Meeting Assistant — Environment Configuration ─────────────────────────
# Copy this file to `.env` and fill in your own values.
# Never commit your actual `.env` file — it is already listed in .gitignore.

# ── Groq (required) ───────────────────────────────────────────────────────
# Used by core/llm_client.py for summarization, insight extraction, and Q&A.
# Get a key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Optional: override the default Groq model.
# LLM_MODEL=llama-3.3-70b-versatile

# ── Sarvam AI (required only for Hinglish/Hindi transcription) ───────────────
# Used by core/audio_transcription.py when language="hinglish" is selected.
# Not needed if you only transcribe English audio (Whisper is used instead
# and runs fully locally).
# Get a key at: https://www.sarvam.ai/
SARVAM_API_KEY=your_sarvam_api_key_here

# Optional: override the default Sarvam STT-translate model.
# SARVAM_STT_MODEL=saaras:v2.5

# ── Whisper (optional) ────────────────────────────────────────────────────
# Local model size used for English transcription.
# One of: tiny, base, small, medium, large (larger = more accurate, slower).
# WHISPER_MODEL=small
